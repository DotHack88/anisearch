# ============================================================
# AniSearch — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# --- Backend (Python/FastAPI) ---

# Redis URL for caching (optional — app works without Redis)
REDIS_URL=redis://localhost:6379

# Admin token for protected endpoints like POST /cache/refresh
# Leave empty to disable auth (dev mode)
ADMIN_TOKEN=

# Comma-separated list of allowed CORS origins
# Default allows localhost dev servers; set to your domain in production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Frontend (Vite/React) ---

# Backend API URL (used when frontend is deployed separately from backend)
# In dev mode with Vite proxy, this defaults to /api
VITE_API_URL=/api
