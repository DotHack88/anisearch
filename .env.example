# ============================================================
# AniSearch — Variabili d'ambiente
# Copia questo file in .env e compila i valori.
# ============================================================

# --- Frontend (Vite) ---

# URL del backend (Render) — OBBLIGATORIO su Vercel
# Impostare questa variabile nelle impostazioni di Vercel:
#   Dashboard → Project → Settings → Environment Variables
VITE_API_URL=https://anisearch-8jph.onrender.com

# --- Backend ---

# Token per proteggere gli endpoint admin (/cache/refresh)
# Genera un token sicuro con: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=cambia-questo-valore

# URL del server Redis per il caching delle ricerche (opzionale)
# Se non impostato, l'app funziona senza cache Redis
REDIS_URL=redis://localhost:6379

# Origini consentite per CORS, separate da virgola
# In sviluppo: http://localhost:5173
# In produzione: https://anisearch-eta.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,https://anisearch-eta.vercel.app

# Numero di worker Uvicorn (NON aumentare: lo scheduler gira in-process)
UVICORN_WORKERS=1

# Abilita endpoint debug (solo sviluppo locale, mai in produzione)
DEBUG_MODE=false

# --- Database ---

# URL PostgreSQL (Neon.tech) — lasciare vuoto per SQLite locale
DATABASE_URL=
